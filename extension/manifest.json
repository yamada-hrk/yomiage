{
  "manifest_version": 3,
  "name": "小説読み上げ (VOICEVOX)",
  "version": "1.2.0",
  "description": "VOICEVOXを使って小説家になろうとカクヨムの小説を読み上げます",
  "permissions": ["activeTab", "storage", "tabs"],
  "host_permissions": [
    "https://ncode.syosetu.com/*",
    "https://kakuyomu.jp/*",
    "http://*:50021/*"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "小説読み上げ"
  },
  "content_scripts": [
    {
      "matches": [
        "https://ncode.syosetu.com/*/*",
        "https://kakuyomu.jp/works/*/episodes/*"
      ],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "background": {
    "service_worker": "background.js"
  }
}
